FROM public.ecr.aws/docker/library/rust:1.91.0-bookworm AS builder
WORKDIR /app

RUN apt-get update -y && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev clang cmake git && rm -rf /var/lib/apt/lists/*

COPY Cargo.toml Cargo.lock ./
COPY . .

RUN cargo build -p apps --bin dsolver-tycho-broadcaster-service --release


FROM public.ecr.aws/debian/debian:bookworm-slim AS runner
RUN apt-get update -y && apt-get install -y --no-install-recommends \
    ca-certificates openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/target/release/dsolver-tycho-broadcaster-service /usr/local/bin/dsolver-tycho-broadcaster-service
COPY --from=builder /app/simulator-manifest.toml /app/simulator-manifest.toml

RUN useradd -m appuser
USER appuser

ENTRYPOINT ["dsolver-tycho-broadcaster-service"]
