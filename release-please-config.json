{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore${scope}: release ${version}",
  "pull-request-header": "This PR was generated automatically by Release Please. Merging it publishes the version below and triggers release-deploy (semver image build to ECR + bump PR in solver-iac).",
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Docs", "hidden": true },
    { "type": "style", "section": "Style", "hidden": true },
    { "type": "chore", "section": "Chores", "hidden": true },
    { "type": "refactor", "section": "Refactor", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Build", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true }
  ],
  "packages": {
    ".": {
      "package-name": "",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
